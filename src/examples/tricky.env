# A deliberately tricky .env, exercising the corner cases of the parser.
# Run it with:  ./build/src/examples/env_to_kvs src/examples/tricky.env

# --- keys ---
export EXPORTED=is-dropped-from-key       # "export " prefix is stripped
my.key-1=dots-and-dashes-ok               # keys are taken verbatim

# --- values with delimiters ---
DB=postgres://user:pass@host:5432/db?sslmode=require   # '=', ':', '@', '?'
EXPR=a = b                                 # only the first '=' splits
FRAGMENT=a#b                               # '#' with no leading space is kept

# --- comments & whitespace ---
COMMENTED=value        # this trailing comment is dropped
ONLY_COMMENT=          # value here is empty
PADDED="  keep my spaces  "                # quotes preserve inner spaces

# --- quoting & escapes ---
LITERAL='no $EXPANSION and a # here'       # single quotes: fully literal
ESCAPES="line1\nline2\ttabbed"             # \n and \t are interpreted
QUOTED_HASH="value # not-a-comment"        # '#' inside quotes stays
ESCAPED_DOLLAR="\$KEEP_ME"                 # \$ emits a literal '$'
MULTILINE="first
second
third"                                     # double quotes may span lines

# --- expansion (resolved through the get callback) ---
HOST=localhost
PORT=8080
SCHEME=https
URL=$SCHEME://$HOST:$PORT/app              # several refs in one value
BRACED=${HOST}_${PORT}                     # ${VAR} form, adjacent
MISSING=[$NOT_DEFINED]                     # unknown -> empty
BARE_DOLLAR=cost is 5$                     # a lone '$' stays literal
